# AAFP Environment Variables
# Copy this file to .env and fill in your API keys.
# NEVER commit the .env file — it is gitignored.

# Firecrawl API key for web browsing (https://www.firecrawl.dev)
FIRECRAWL_API_KEY=fc-your-key-here

# Brave Search API key (optional, for search — https://brave.com/search/api)
# DuckDuckGo is used as the free default search provider.
BRAVE_SEARCH_API_KEY=

# SerpApi key (optional, Google search fallback — https://serpapi.com)
SERPAPI_KEY=
